{
  "manifest_version": 3,
  "name": "Jira Story Point Poker",
  "description": "Anonymous shared story point voting for Jira tickets.",
  "version": "1.0.0",
  "action": {
    "default_title": "Story Point Poker"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": [
    "https://muzwzxewfkwappezcgzx.supabase.co/*",
    "https://*.jira.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.jira.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
